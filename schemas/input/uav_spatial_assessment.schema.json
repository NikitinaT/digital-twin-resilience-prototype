{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/input/uav_spatial_assessment.schema.json",
  "title": "UAV Spatial Assessment Event",
  "type": "object",
  "required": [
    "header",
    "payload"
  ],
  "properties": {
    "header": {
      "allOf": [
        {
          "$ref": "../common.defs.json#/$defs/event_header"
        },
        {
          "type": "object",
          "properties": {
            "event_type": {
              "const": "uav.spatial.assessment"
            }
          },
          "required": [
            "event_type"
          ]
        }
      ]
    },
    "payload": {
      "type": "object",
      "required": [
        "mission_id",
        "observed_assets"
      ],
      "properties": {
        "mission_id": {
          "type": "string",
          "minLength": 1
        },
        "observed_assets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "asset_type",
              "asset_id",
              "damage_grade"
            ],
            "properties": {
              "asset_type": {
                "type": "string",
                "enum": [
                  "building",
                  "power_node",
                  "network_node",
                  "route",
                  "other"
                ]
              },
              "asset_id": {
                "type": "string",
                "minLength": 1
              },
              "damage_grade": {
                "type": "integer",
                "minimum": 0,
                "maximum": 5,
                "description": "0=no damage, 5=destroyed"
              },
              "geometry": {
                "$ref": "../common.defs.json#/$defs/geojson_polygon"
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "media_refs": {
          "type": "object",
          "properties": {
            "images": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "video": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          },
          "additionalProperties": false
        },
        "derived_metrics": {
          "type": "object",
          "properties": {
            "damage_probability": {
              "$ref": "../common.defs.json#/$defs/probability"
            },
            "blocked_routes": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}