{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/output/dt_decision_directive.schema.json",
  "title": "Digital Twin Decision Directive",
  "type": "object",
  "required": [
    "decision_id",
    "generated_at",
    "state_context",
    "inputs_used",
    "confidence",
    "actions"
  ],
  "properties": {
    "decision_id": {
      "$ref": "../common.defs.json#/$defs/uuid"
    },
    "generated_at": {
      "$ref": "../common.defs.json#/$defs/iso_datetime_utc"
    },
    "state_context": {
      "type": "string",
      "enum": [
        "S0",
        "S1",
        "S2",
        "S3"
      ]
    },
    "inputs_used": {
      "type": "array",
      "items": {
        "$ref": "../common.defs.json#/$defs/uuid"
      },
      "minItems": 1
    },
    "rationale": {
      "type": "string",
      "maxLength": 600
    },
    "confidence": {
      "$ref": "../common.defs.json#/$defs/probability"
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "action_type",
          "priority",
          "target",
          "parameters"
        ],
        "properties": {
          "action_type": {
            "type": "string",
            "enum": [
              "tier_activation",
              "energy_allocation",
              "load_shedding",
              "evacuation_routing",
              "schedule_reconfiguration",
              "lab_relocation",
              "inspection_dispatch",
              "network_failover",
              "public_communication"
            ]
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "target": {
            "type": "object",
            "properties": {
              "zone_id": {
                "type": "string"
              },
              "building_id": {
                "type": "string"
              },
              "system": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "parameters": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}